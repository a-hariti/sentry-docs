{
  "extends": "@sentry-docs/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "sentry/ui-shared/*": [
        "src/*"
      ]
    },
    "strictNullChecks": false,
    "allowSyntheticDefaultImports": true
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts",
    "tsconfig.lint.json"
  ],
  "exclude": [
    "node_modules"
  ]
}
